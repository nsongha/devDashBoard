# Dev Dashboard — Environment Variables Template
# Copy file này thành .env và điền giá trị thật

# Gemini AI API Key (lấy tại https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# GitHub Personal Access Token (lấy tại https://github.com/settings/tokens)
GITHUB_TOKEN=

# GitHub repo mặc định để hiển thị PRs/Issues
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# GitHub Webhook Secret (tùy chọn — dùng khi cấu hình webhook)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
