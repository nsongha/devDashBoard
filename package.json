{
  "name": "dev-dashboard",
  "version": "0.6.0",
  "description": "AI-Assisted Development Dashboard — Visualize project stats, phases, workflows from git + docs",
  "type": "module",
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "bash scripts/dev.sh",
    "kill-port": "lsof -ti :${PORT:-4321} | xargs kill -9 2>/dev/null || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
