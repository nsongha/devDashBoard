<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#12121e"/>
      <stop offset="100%" stop-color="#1a1a2e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#7c6cf0"/>
      <stop offset="100%" stop-color="#a78bfa"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="10.24" result="coloredBlur"/>
      <feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)" rx="0"/>

  <!-- Outer ring -->
  <circle cx="256" cy="256" r="180.22400000000002" fill="none" stroke="url(#accent)" stroke-width="12.8" opacity="0.4"/>

  <!-- Inner glow circle -->
  <circle cx="256" cy="256" r="112.64000000000001" fill="url(#accent)" opacity="0.12" filter="url(#glow)"/>

  <!-- Grid lines (code aesthetic) -->
  <line x1="153.6" y1="133.12" x2="358.4" y2="133.12" stroke="#7c6cf0" stroke-width="6.144" opacity="0.3"/>
  <line x1="153.6" y1="215.04" x2="358.4" y2="215.04" stroke="#7c6cf0" stroke-width="4.096" opacity="0.2"/>
  <line x1="153.6" y1="296.96000000000004" x2="358.4" y2="296.96000000000004" stroke="#7c6cf0" stroke-width="4.096" opacity="0.2"/>

  <!-- "DD" monogram -->
  <text
    x="256"
    y="306.05"
    font-family="'JetBrains Mono', 'Fira Code', monospace"
    font-size="143"
    font-weight="700"
    text-anchor="middle"
    fill="url(#accent)"
    filter="url(#glow)"
  >DD</text>

  <!-- Accent dot -->
  <circle cx="368.64" cy="143.35999999999999" r="20.48" fill="#22c55e" opacity="0.9"/>
</svg>